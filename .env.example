# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$...bcrypt-hash-of-your-password

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=options_research
POSTGRES_USER=options_user
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://options_user:change-me-postgres-password@postgres:5432/options_research

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Kite Connect (READ-ONLY market data) ────────────────────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ─── LLM: Anthropic ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── LLM: Groq (free tier — research + monitor agents) ───────────────────────
GROQ_API_KEY=

# ─── LLM: Ollama (local fallback on Mac Mini) ────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Notifications ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# ─── Cloudflare Tunnel ───────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Feature Flags ───────────────────────────────────────────────────────────
PAPER_TRADING_ENABLED=true
LIVE_DATA_ENABLED=false
